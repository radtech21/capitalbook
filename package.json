{
  "name": "capital-book-backend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Capital Book CRM API (Express + MySQL)",
  "scripts": {
    "migrate": "tsx scripts/migrate.ts",
    "migrate:schema": "tsx scripts/migrate.ts --until 004",
    "seed": "tsx seeds/seed.ts",
    "setup": "npm run migrate:schema && npm run seed && npm run migrate",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "seed:users": "tsx seeds/users.ts",
    "set-password": "tsx scripts/set-password.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.0",
    "nodemailer": "^9.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.5.0",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^6.0.2",
    "smtp-server": "^3.19.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}