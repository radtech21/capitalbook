# --- Database (MySQL / MariaDB) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=cbuser
DB_PASSWORD=cbpass
DB_NAME=capitalbook
DB_POOL=10

# --- Auth ---
# CHANGE THIS before exposing the API beyond localhost.
JWT_SECRET=dev-secret-change-me-in-production
JWT_EXPIRES=12h

# --- Server ---
PORT=4000
# Comma-separated list of allowed CORS origins, or * for any (default).
CORS_ORIGIN=*

# --- Seed ---

# --- Password reset email (required for "Forgot password?" on the sign-in screen) ---
# Without these, reset falls back to an admin setting the password from the Users panel.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Capital Book <no-reply@ninepoint.com>"
# Where the frontend is served. Reset links are built from this.
APP_URL=http://localhost:5173

# --- Access ---
# Self-registration is OFF unless this is exactly "true". Admins add users in-app.
ALLOW_REGISTRATION=false

# --- Seed ---
# If set, all three seeded accounts get this password. Otherwise each gets a
# random one, printed once by `npm run seed`.
SEED_USER_PASSWORD=
